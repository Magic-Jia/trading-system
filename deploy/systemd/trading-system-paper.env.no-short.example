# Install as: /etc/default/trading-system-paper
# Canonical runtime config for both deploy/systemd/trading-system-paper.service
# and deploy/cron/trading-system-paper-cron.sh.
# The cron wrapper no longer falls back to any workspace env file; if this file
# is missing, the wrapper exits non-zero before starting a cycle.

TRADING_EXECUTION_MODE=paper
TRADING_RUNTIME_ENV=paper
TRADING_BASE_DIR=/opt/trading-system/trading_system

# Runtime no_short switch: disable short engine before candidate generation/allocation.
TRADING_DISABLED_ENGINES=short

# Optional explicit mirror; harmless with the runtime engine disable above.
TRADING_ALLOCATOR_SHORT_BUCKET_WEIGHT=0.00
